#!/bin/bash
# cpa-health - Codex 账号健康检查 / 清理
#
# 检测: 过期 / 额度耗尽 / 疑似封号 / 高失败率
# 用量: 时间线柱状图 + 配额百分比估算
#
# 用法:
#   cpa-health                  # 健康检查
#   cpa-health --clean          # 清理问题账号 (需确认)
#   cpa-health --clean --force  # 清理不确认

set -e

CPA_PORT=${CPA_PORT:-8317}
AUTH_DIR="${CPA_AUTH_DIR:-$HOME/.cli-proxy-api}"
[ -d "$AUTH_DIR" ] || AUTH_DIR="/root/.cli-proxy-api"

# ── 自动找管理密钥: env > .mgmt_key > config.yaml明文 ──
find_mgmt_key() {
    [ -n "$CPA_MANAGEMENT_KEY" ] && echo "$CPA_MANAGEMENT_KEY" && return
    for kf in /root/.cli-proxy-api/.mgmt_key ~/.cli-proxy-api/.mgmt_key; do
        [ -f "$kf" ] && cat "$kf" && return
    done
    for cp in /root/cliproxyapi/config.yaml /home/*/cliproxyapi/config.yaml /opt/cliproxyapi/config.yaml; do
        [ -f "$cp" ] || continue
        python3 -c "
import yaml
with open('$cp') as f:
    sk = yaml.safe_load(f).get('remote-management',{}).get('secret-key','')
if not sk.startswith('\$2a\$'): print(sk)
" 2>/dev/null | grep -v '^\$' && return
    done
}

MGMT_KEY="${CPA_MANAGEMENT_KEY:-$(find_mgmt_key)}"

CLEAN_MODE=false; FORCE=false
for arg in "$@"; do
    case "$arg" in
        --clean) CLEAN_MODE=true ;;
        --force) FORCE=true ;;
        --help|-h) echo "用法: cpa-health [--clean] [--force]"; exit 0 ;;
    esac
done

echo "============================================"
echo " CPA Codex 账号健康检查"
echo "============================================"
echo ""

python3 << PYEOF
import json, os, sys, base64, time, subprocess
from pathlib import Path
from datetime import datetime, timezone

AUTH_DIR = Path("$AUTH_DIR")
MGMT_KEY = "$MGMT_KEY"
CLEAN_MODE = "$CLEAN_MODE" == "true"
FORCE = "$FORCE" == "true"
CPA_PORT = "$CPA_PORT"
now = time.time()

def decode_jwt(token):
    try:
        p = token.split(".")[1]; p += "=" * (4 - len(p) % 4)
        return json.loads(base64.urlsafe_b64decode(p))
    except: return {}

def fetch_auth_status():
    if not MGMT_KEY: return {}
    try:
        r = subprocess.run(["curl","-s","--max-time","5",
            "-H",f"X-Management-Key: {MGMT_KEY}",
            f"http://127.0.0.1:{CPA_PORT}/v0/management/auth-files"],
            capture_output=True, text=True)
        return {f["email"]: f for f in json.loads(r.stdout).get("files",[]) if f.get("email")}
    except: return {}

api_status = fetch_auth_status()
print(f"📡 {'已连接' if api_status else '⚠ 未连接'} CPA 管理 API{' (仅检查JWT)' if not api_status else ''}")
print()

files = sorted(AUTH_DIR.glob("*.json"))
if not files: print("未找到 auth 文件"); sys.exit(0)

# ── 用量时间线 + 配额估算 ──
PLAN_CAPS = {"free": 100, "pro": 500, "max": 2000, "team": 2000}

def quota_info(live, plan):
    if not live: return "", "", ""
    recent = live.get("recent_requests", [])
    if not recent: return "", "", ""

    # 时间线 (最近12格)
    slots = recent[-12:]
    chars = []
    for r in slots:
        s, f = r.get("success",0), r.get("failed",0)
        if s>0 and f==0: chars.append("█")
        elif f>0 and s==0: chars.append("✗")
        elif s>0 and f>0: chars.append("▦")
        else: chars.append("·")
    ts = sum(r.get("success",0) for r in slots)
    tf_ = sum(r.get("failed",0) for r in slots)
    timeline = f"{''.join(chars)} {ts}✓{tf_}✗"

    # 配额估算: 跟踪窗口(~3h) → 推算全天
    all_s = sum(r.get("success",0) for r in recent)
    all_f = sum(r.get("failed",0) for r in recent)
    if len(recent) < 3 or all_s + all_f == 0:
        return timeline, "", ""

    hours = len(recent) * 10 / 60
    daily = (all_s + all_f) * (24 / max(hours, 1))
    cap = PLAN_CAPS.get(plan, 100)
    pct = min(100, int(daily / cap * 100))
    n = 6
    f_ = min(n, max(1, int(pct/100*n)))
    bar = f"{'█'*f_}{'░'*(n-f_)} {pct}%"
    return timeline, pct, bar

# ── 分析每个账号 ──
total = 0
results = []

for f in files:
    try:
        with open(f) as fh: data = json.load(fh)
    except: continue
    if data.get("type") != "codex": continue
    total += 1

    email = data.get("email","?")
    plan = data.get("plan_type","free")
    issues = []
    severity = "ok"

    # JWT 过期
    token = data.get("access_token","")
    jwt_days = 0
    if token:
        jwt = decode_jwt(token)
        exp = jwt.get("exp",0)
        if exp:
            jwt_days = (exp - now) / 86400
            if jwt_days < 0:
                issues.append("JWT已过期"); severity = "bad"
            elif jwt_days < 3:
                issues.append(f"JWT {jwt_days:.0f}天后过期")
                if severity == "ok": severity = "warn"

    # 业务过期
    es = data.get("expired","?")
    if es and es != "?":
        try:
            ed = datetime.fromisoformat(es.replace("Z","+00:00"))
            if ed.timestamp() < now:
                issues.append("账号标记过期"); severity = "bad"
        except: pass

    # CPA 实时状态
    live = api_status.get(email, {})
    all_time_s = all_time_f = 0
    if live:
        recent = live.get("recent_requests",[])
        all_slots = [(r.get("success",0), r.get("failed",0)) for r in recent]
        total_s = sum(s for s,_ in all_slots)
        total_f = sum(f for _,f in all_slots)
        total_r = total_s + total_f
        r30_s = sum(s for s,_ in all_slots[-3:])
        r30_f = sum(f for _,f in all_slots[-3:])
        r60_s = sum(s for s,_ in all_slots[-6:])
        r60_f = sum(f for _,f in all_slots[-6:])

        if total_r > 0 or live.get("unavailable") or live.get("disabled"):
            if live.get("unavailable"):
                if r60_s > 0: issues.append("CPA冷却中(曾可用)")
                elif r60_f > 0: issues.append("额度耗尽/冷却中")
                else: issues.append("CPA标记不可用")
                if severity == "ok": severity = "warn"

            if live.get("disabled"):
                issues.append("已禁用"); severity = "bad"

            # 封号: 从未成功, 只有失败
            if total_s == 0 and total_f >= 2:
                issues.append(f"🚫 疑似封号: 累计{total_f}次全失败")
                severity = "banned"
            # 额度耗尽: 曾成功, 最近全失败
            elif total_s > 0 and r30_s == 0 and r30_f >= 1:
                issues.append("额度耗尽: 最近无成功")
                if severity == "ok": severity = "warn"
            elif total_s > 0 and r60_s == 0 and r60_f >= 2:
                issues.append("额度耗尽: 最近全部失败")
                if severity == "ok": severity = "warn"

            # 失败率
            if total_r >= 5 and total_f > 0 and severity == "ok":
                fr = total_f / total_r
                if fr >= 0.6: issues.append(f"高失败率: {total_f}/{total_r}"); severity = "bad"
                elif fr >= 0.3: issues.append(f"失败率偏高: {total_f}/{total_r}"); severity = "warn"

        sm = live.get("status_message","")
        if sm: issues.append(f"状态: {sm}")
        all_time_s = live.get("success",0)
        all_time_f = live.get("failed",0)

    results.append((email, plan, severity, issues, jwt_days, f, all_time_s, all_time_f, live))

# ── 排序 ──
def sort_key(r):
    _, _, sev, _, _, _, ok_c, fail_c, live = r
    sev_order = {"banned":0,"bad":1,"warn":2,"ok":3}
    recent = live.get("recent_requests",[]) if live else []
    r_total = sum(rr.get("success",0)+rr.get("failed",0) for rr in recent[-6:])
    return (sev_order.get(sev,9), -r_total)
results.sort(key=sort_key)

# ── 显示 ──
icons = {"ok":"✓","warn":"⚠","bad":"✗","banned":"🚫"}
ok_n = warn_n = bad_n = banned_n = 0

for email, plan, sev, issues, jwt_days, f, ok_c, fail_c, live in results:
    icon = icons.get(sev,"?")
    timeline, pct, quota_bar = quota_info(live, plan)

    tag = ""
    if sev not in ("bad","banned","warn"):
        if live and live.get("unavailable"):
            tag = " [额度耗尽]"; quota_bar = "██████ 100%"
        elif ok_c + fail_c == 0:
            tag = " [新账号]"

    line = f"  {icon} {email}"
    if timeline: line += f"  {timeline}"
    if quota_bar: line += f"  {quota_bar}"
    line += f"  JWT:{jwt_days:.0f}d{tag}"
    print(line)
    for iss in issues:
        print(f"     ⮡ {iss}")

    if sev == "ok":
        if live and live.get("unavailable"): warn_n += 1
        else: ok_n += 1
    elif sev == "warn": warn_n += 1
    elif sev == "bad": bad_n += 1
    elif sev == "banned": banned_n += 1

print()
print("───")
print(f"总计: {total} | ✓{ok_n} ⚠{warn_n} ✗{bad_n} 🚫{banned_n}")
print(f"每格=10min  █成功 ·空闲 ✗失败  配额=当日估算")

# ── 清理 ──
to_clean = [r for r in results if r[2] in ("bad","banned")]
if to_clean:
    print(f"\n建议清理 ({len(to_clean)} 个):")
    for r in to_clean:
        print(f"  {icons[r[2]]} {r[0]}  {'|'.join(r[3])}")
    if CLEAN_MODE:
        print(f"\n将要删除 {len(to_clean)} 个问题账号:")
        for r in to_clean:
            print(f"  - {r[0]}    {'|'.join(r[3])}")
        if not FORCE:
            try: resp = input("\n确认删除? [y/N] ").strip().lower()
            except EOFError: resp = "n"
            if resp not in ("y","yes"): print("已取消"); sys.exit(0)
        for r in to_clean:
            try: r[5].unlink()
            except: pass
        print(f"\n✅ 已删除 {len(to_clean)} 个问题账号")
        print("   CPA 文件监控会自动感知变更")
elif not CLEAN_MODE:
    print("\n运行 cpa-health --clean 清理问题账号")

PYEOF
