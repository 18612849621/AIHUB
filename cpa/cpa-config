#!/bin/bash
# cpa-config - 一键输出 Codex + Claude Code 配置
# 纯打印到屏幕, 直接复制粘贴

CPA_PORT=${CPA_PORT:-8317}
MAPPER_PORT=8080

# ── 公网/内网 IP ──
PUBLIC_IP=$(curl -s --max-time 3 https://ifconfig.me 2>/dev/null || \
            curl -s --max-time 3 https://api.ipify.org 2>/dev/null || \
            curl -s --max-time 3 http://ipinfo.io/ip 2>/dev/null)
LAN_IP=$(hostname -I | awk '{print $1}')
[ -z "$LAN_IP" ] && LAN_IP="127.0.0.1"

if [ -n "$PUBLIC_IP" ]; then
    CPA_URL="http://${PUBLIC_IP}:${CPA_PORT}"
    MAPPER_URL="http://${PUBLIC_IP}:${MAPPER_PORT}"
    LAN_CPA="http://${LAN_IP}:${CPA_PORT}"
else
    CPA_URL="http://${LAN_IP}:${CPA_PORT}"
    MAPPER_URL="http://${LAN_IP}:${MAPPER_PORT}"
    LAN_CPA=""
fi

# ── API Key ──
for p in /root/cliproxyapi/config.yaml /home/*/cliproxyapi/config.yaml /opt/cliproxyapi/config.yaml ./config.yaml; do
    [ -f "$p" ] && CPA_CONFIG="$p" && break
done

API_KEY=$(python3 -c "
import yaml
with open('$CPA_CONFIG') as f:
    keys = yaml.safe_load(f).get('api-keys', [])
print(keys[0] if keys else '')
" 2>/dev/null)

[ -z "$API_KEY" ] && echo "❌ 未找到 CPA API key" && exit 1

MODEL=${CPA_MODEL:-"gpt-5.5"}

# ═══════════════════════════════════
# Codex CLI
# ═══════════════════════════════════
echo "============================================"
echo " Codex CLI  →  ~/.codex/config.toml"
echo "============================================"
echo ""

cat <<TOML
model_provider = "codex"
model = "$MODEL"
model_reasoning_effort = "xhigh"
disable_response_storage = true
preferred_auth_method = "apikey"

[model_providers.codex]
name = "OpenAI"
base_url = "$CPA_URL/v1"
experimental_bearer_token = "$API_KEY"
wire_api = "responses"

[features]
memories = true

[memories]
use_memories = true
generate_memories = true

[analytics]
enabled = false

[otel]
exporter = "none"
trace_exporter = "none"
metrics_exporter = "none"

[feedback]
enabled = false

[tui.model_availability_nux]
"$MODEL" = 4
TOML

# ═══════════════════════════════════
# Claude Code
# ═══════════════════════════════════
echo ""
echo "============================================"
echo " Claude Code  →  终端环境变量"
echo "  claude-* 自动映射 → $MODEL"
echo "============================================"
echo ""

cat <<ENV
export ANTHROPIC_BASE_URL='${MAPPER_URL}/v1'
export ANTHROPIC_API_KEY='$API_KEY'
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
export CLAUDE_CODE_EFFORT_LEVEL=max
ENV

echo ""
echo "============================================"
echo " 服务:   CPA → $CPA_URL"
echo " 映射代理 → $MAPPER_URL  (claude-* → $MODEL)"
echo " 默认模型: $MODEL (export CPA_MODEL=xxx 覆盖)"
echo "============================================"
