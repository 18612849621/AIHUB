#!/bin/bash
# cpa-config - Codex CLI 配置
# 纯打印到屏幕, 直接复制粘贴

CPA_PORT=${CPA_PORT:-8317}

# ── 公网/内网 IP ──
PUBLIC_IP=$(curl -s --max-time 3 https://ifconfig.me 2>/dev/null || \
            curl -s --max-time 3 https://api.ipify.org 2>/dev/null || \
            curl -s --max-time 3 http://ipinfo.io/ip 2>/dev/null)
LAN_IP=$(hostname -I | awk '{print $1}')
[ -z "$LAN_IP" ] && LAN_IP="127.0.0.1"

if [ -n "$PUBLIC_IP" ]; then
    CONFIG_URL="http://${PUBLIC_IP}:${CPA_PORT}"
    LAN_URL="http://${LAN_IP}:${CPA_PORT}"
else
    CONFIG_URL="http://${LAN_IP}:${CPA_PORT}"
    LAN_URL=""
fi

# ── API Key ──
for p in /root/cliproxyapi/config.yaml /home/*/cliproxyapi/config.yaml /opt/cliproxyapi/config.yaml ./config.yaml; do
    [ -f "$p" ] && CPA_CONFIG="$p" && break
done

API_KEY=$(python3 -c "
import yaml
with open('$CPA_CONFIG') as f:
    keys = yaml.safe_load(f).get('api-keys', [])
print(keys[0] if keys else '')
" 2>/dev/null)

[ -z "$API_KEY" ] && echo "❌ 未找到 CPA API key" && exit 1

MODEL=${CPA_MODEL:-"gpt-5.5"}

echo "# ── 复制以下内容到 ~/.codex/config.toml ──"
echo ""

cat <<TOML
model_provider = "codex"
model = "$MODEL"
model_reasoning_effort = "xhigh"
disable_response_storage = true
preferred_auth_method = "apikey"

[model_providers.codex]
name = "OpenAI"
base_url = "$CONFIG_URL/v1"
# base_url = "${LAN_URL}/v1"  (内网)
experimental_bearer_token = "$API_KEY"
wire_api = "responses"

[features]
memories = true

[memories]
use_memories = true
generate_memories = true

[analytics]
enabled = false

[otel]
exporter = "none"
trace_exporter = "none"
metrics_exporter = "none"

[feedback]
enabled = false

[tui.model_availability_nux]
"$MODEL" = 4
TOML

echo ""
echo "# ── 或直接 export ──"
echo ""
echo "export OPENAI_API_KEY='$API_KEY'"

echo ""
echo "============================================"
echo " 公网: $CONFIG_URL"
[ -n "$LAN_URL" ] && echo " 内网: $LAN_URL"
echo " 默认模型: $MODEL (export CPA_MODEL=xxx 覆盖)"
echo "============================================"
