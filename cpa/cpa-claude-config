#!/bin/bash
# cpa-claude-config - 生成 Claude Code CLI 配置 (走 CPA 的 GPT 模型)
# 纯打印到屏幕, 直接复制粘贴

CPA_PORT=${CPA_PORT:-8317}

# 公网 IP
PUBLIC_IP=$(curl -s --max-time 3 https://ifconfig.me 2>/dev/null || \
            curl -s --max-time 3 https://api.ipify.org 2>/dev/null || \
            curl -s --max-time 3 http://ipinfo.io/ip 2>/dev/null)
LAN_IP=$(hostname -I | awk '{print $1}')
[ -z "$LAN_IP" ] && LAN_IP="127.0.0.1"

if [ -n "$PUBLIC_IP" ]; then
    CONFIG_URL="http://${PUBLIC_IP}:${CPA_PORT}"
    LAN_URL="http://${LAN_IP}:${CPA_PORT}"
else
    CONFIG_URL="http://${LAN_IP}:${CPA_PORT}"
    LAN_URL=""
fi

# 自动查找 config.yaml
if [ -z "$CPA_CONFIG" ]; then
    for p in /root/cliproxyapi/config.yaml /home/*/cliproxyapi/config.yaml /opt/cliproxyapi/config.yaml ./config.yaml; do
        [ -f "$p" ] && CPA_CONFIG="$p" && break
    done
fi

API_KEY=$(python3 -c "
import yaml
with open('$CPA_CONFIG') as f:
    cfg = yaml.safe_load(f)
keys = cfg.get('api-keys', [])
print(keys[0] if keys else '')
" 2>/dev/null)

if [ -z "$API_KEY" ]; then
    echo "❌ 未找到 CPA API key"
    exit 1
fi

MODEL=${CPA_MODEL:-"gpt-5.5"}

echo "============================================"
echo " Claude Code CLI 配置 (走 CPA → GPT)"
echo "============================================"
echo ""
echo "# ── 环境变量 (复制到终端执行) ──"
echo ""

# 内网注释
LAN_COMMENT=""
[ -n "$LAN_URL" ] && LAN_COMMENT=" (内网)"

# 模型名去横线 (gpt-5.5 → gpt5.5)
MODEL_SHORT="${MODEL//-/}"

cat <<EOF
export ANTHROPIC_AUTH_TOKEN='$API_KEY'
export ANTHROPIC_BASE_URL='${CONFIG_URL}/v1'
# export ANTHROPIC_BASE_URL='${LAN_URL}/v1'$LAN_COMMENT
export ANTHROPIC_API_KEY='$API_KEY'
export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
export ANTHROPIC_MODEL=$MODEL_SHORT
export ANTHROPIC_DEFAULT_OPUS_MODEL=$MODEL_SHORT
export ANTHROPIC_DEFAULT_SONNET_MODEL=$MODEL_SHORT
export ANTHROPIC_DEFAULT_HAIKU_MODEL=$MODEL_SHORT
export CLAUDE_CODE_SUBAGENT_MODEL=$MODEL_SHORT
export CLAUDE_CODE_EFFORT_LEVEL=max
export CLAUDE_CODE_ATTRIBUTION_HEADER=0
export IS_SANDBOX=1
EOF

echo ""
echo "============================================"
echo " 公网: $CONFIG_URL"
[ -n "$LAN_URL" ] && echo " 内网: $LAN_URL"
echo " 默认模型: $MODEL (可 export CPA_MODEL=xxx 覆盖)"
echo ""
echo " 可用模型:"
echo "============================================"
echo ""

curl -s --max-time 5 -H "Authorization: Bearer $API_KEY" "${CONFIG_URL}/v1/models" 2>/dev/null | \
  python3 -c "
import json, sys
try:
    data = json.load(sys.stdin)
    for m in data.get('data', []):
        mid = m.get('id', '')
        print(f'  {mid}')
except: pass
" 2>/dev/null
